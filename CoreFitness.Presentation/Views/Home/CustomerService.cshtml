<!-- Kopplad till Controllers/HomeController.cs -->
<!--För att det ska stå "CustomerService" i webbläsarens flik-->
@{
    ViewData["Title"] = "Customer Service";
}

<div class="cs-bg">
<div class="cs-title">Customer Service</div>



<div class="cs-left-right-container">

<div class="cs-left">
    <div class="icon-container icon-1">
        <img src="~/images/contact-us-img1.svg" alt="ikon 1">
       



    <div class="icon-container icon-2">
        <img src="~/images/contact-us-img2.svg" alt="ikon 2">

    <div class="icon-3-wrapper">
        <img src="~/images/contact-us-img3.svg" alt="phone logo" class="icon-3">
        <div class="icon3textbold">Phone Number</div>
        <div class="icon3text">+(46) 8 410 521 00</div>
    </div>

    <div class="icon-4"></div>
    <div class="icon4textbold">Email Address</div>
    <div class="icon4text">info@corefitness.se</div>
</div> 
    </div>
</div>





<div class="cs-right">
    <div class="cs-right-title">Contact Us Today</div>
    <div class="cs-right-text">Ready to begin your fitness journey? Contact GymPro today and let our 
        expert trainers guide you with the right program and support.</div>

<div class="forum-container">
<div class="forum-1">
    <label for="namn">First Name *</label>
    <input type="text" placeholder="Enter First Name">
    
    <label for="namn">Email Address *</label>
    <input type="text" placeholder="Enter Last Name">
    </div>

<div class="forum-2">
    <label for="namn">Last Name *</label>
    <input type="text" placeholder="Enter Email Address">
    
    <label for="namn">Phone Number</label>
    <input type="text" placeholder="Enter Phone Number">
    </div>
 </div>



<div class="forum-3">
    <label for="namn">Message *</label>
    <textarea placeholder="Message..."></textarea>
</div>




                    <button class="green-btn">Submit Message</button>
                    </div>
    </div>





<partial name="Partials/_Questions" />
<partial name="Partials/_Accordion" />

</div>