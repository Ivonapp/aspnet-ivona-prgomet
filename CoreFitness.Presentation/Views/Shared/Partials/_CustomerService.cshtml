    @* Denna styr så den går till HandleRegister i AuthController *@
<form method="post" asp-controller="Home" asp-action="CustomerService" novalidate>

    <div class="cs-right-title">Contact Us Today</div>
    <div class="cs-right-text">Ready to begin your fitness journey? Contact GymPro today and let our 
        expert trainers guide you with the right program and support.</div>






<div class="forum-grid">
<div class="field">
    <label for="firstName" class="firstname-label">First Name *</label>
    <input asp-for="FirstName" class="name-design"> 
    <span asp-validation-for="FirstName"></span>
</div>   

<div class="field">
    <label for="LastName" class="lastname-label">Last Name *</label>
    <input asp-for="LastName" class="name-design">  
    <span asp-validation-for="LastName"></span>
</div>    

<div class="field">
    <label for="Email" class="emailAddress-label">Email Address *</label>
    <input asp-for="Email" class="email-design">   
    <span asp-validation-for="Email"></span> 
</div>

<div class="field">
        <label for="phoneNumber" class="phone-label">Phone Number</label>
        <input asp-for="PhoneNumber" class="phone-design"> 
        <span asp-validation-for="PhoneNumber"></span>
    </div>
 </div>


<div class="field">
    <label for="namn" class="writebox-label">Message *</label>
    <textarea asp-for="Message" class="message-design"> </textarea>
    <span asp-validation-for="Message"></span>
</div>




                    <button type="submit" class="green-btn forms-btn">Submit Message
